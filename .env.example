# Token JWT de la API REST de Wallet by BudgetBakers (requiere Premium)
# Conseguilo en: https://wallet.budgetbakers.com -> Settings -> REST API
WALLET_API_TOKEN=

# Moneda base que usas en Wallet (para formateo). Ej: COP, USD, EUR
NEXT_PUBLIC_BASE_CURRENCY=COP

# Si lo dejas en "true" la app usa datos mock realistas y no llama a la API
USE_MOCK=true
